                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Pracuję holistycznie — ciało, umysł i emocje traktuję jako całość. W bezpiecznej, pełnej szacunku przestrzeni możesz eksplorować siebie bez oceniania, w swoim własnym tempie. Bo prawdziwa zmiana wymaga zaufania — do siebie i do procesu.",
                      "lineHeight": 1.7,
                      "textAlign": "center",
                      "fontFamily": "Lato",
                      "fontSize": 16,
                      "fontWeight": "normal"
