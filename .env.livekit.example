# =====================================================================
# Spirala — LiveKit infra credentials (.env.livekit)
#
# Used by docker-compose.livekit.yml on the server.
#
#   1. Copy to .env.livekit
#   2. Generate secrets:
#        openssl rand -base64 32   # generates an API_SECRET (>= 32 chars)
#   3. Use the SAME api_key/api_secret value in:
#        - LIVEKIT_DEV_KEYS / LIVEKIT_PROD_KEYS below (server-side keys map)
#        - LIVEKIT_API_KEY / LIVEKIT_API_SECRET in backend/.env (NestJS)
#        - LIVEKIT_API_KEY / LIVEKIT_API_SECRET below (egress reads them)
# =====================================================================

# DEV
# Format: "<key>: <secret>" — note the space after the colon.
LIVEKIT_DEV_KEYS=SpiralaDevKey: <generate-with-openssl-rand-base64-32>
LIVEKIT_API_KEY_DEV=SpiralaDevKey
LIVEKIT_API_SECRET_DEV=<same secret as in LIVEKIT_DEV_KEYS>

# PROD
LIVEKIT_PROD_KEYS=SpiralaProdKey: <generate-with-openssl-rand-base64-32>
LIVEKIT_API_KEY_PROD=SpiralaProdKey
LIVEKIT_API_SECRET_PROD=<same secret as in LIVEKIT_PROD_KEYS>
