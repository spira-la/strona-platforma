# ─── Database ────────────────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=45432
DATABASE_USER=spirala_dev
DATABASE_PASSWORD=
DATABASE_NAME=spirala_dev
DATABASE_SCHEMA=spirala_dev_schema
# DATABASE_SSL=true  # Only for external providers (Supabase, AWS RDS, etc.)

# ─── Server ──────────────────────────────────────────────────────────
PORT=3000

# ─── Supabase (Auth only) ───────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Cloudflare R2 ──────────────────────────────────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=spirala-storage
R2_PUBLIC_URL=https://cdn.spira-la.com

# ─── SMTP ────────────────────────────────────────────────────────────
SMTP_HOST=smtppro.zoho.eu
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@spira-la.com
SMTP_FROM_NAME=Spirala

# ─── Stripe ──────────────────────────────────────────────────────────
# Leave STRIPE_SECRET_KEY empty (or set STRIPE_MOCK_MODE=true) to run the
# full purchase flow with mocked PaymentIntent responses. When the real
# key is set, the same endpoints process real cards — no code changes.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MOCK_MODE=true

# ─── LiveKit (self-hosted video server for 1-on-1 sessions + webinars) ─
# The LiveKit server for Spirala is expected at stream.spira-la.com.
# Values match what BeWonderMe used (same pattern, new hostname).
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_HTTP_URL=https://stream.spira-la.com
LIVEKIT_PUBLIC_WS_URL=wss://stream.spira-la.com

# ─── LiveKit Egress / HLS recording (active for 1-on-1 session recording) ─
# The egress Chrome loads this URL with `/<bookingId>?recordingKey=...&internalApiUrl=...`
# appended automatically. The frontend route /recording-template/:bookingId is the
# minimal page that joins the LiveKit room as a viewer and renders a grid the
# egress captures. Recordings end up in Cloudflare R2 (R2_BUCKET).
RECORDING_TEMPLATE_URL=https://dev.spira-la.com/recording-template
# Generate a random secret: openssl rand -base64 32
# This must match what the frontend sees via internalApiUrl when validating.
RECORDING_API_KEY=
# Docker-internal API URL Chrome can resolve (Chrome inside egress container
# can't reach the public API domain).
RECORDING_INTERNAL_API_URL=http://spirala-be-dev:3000
HLS_OUTPUT_PATH=/hls
HLS_BASE_URL=https://streamdev.spira-la.com/hls

# ─── Frontend URL (used to build meeting links in booking emails) ────
FRONTEND_URL=https://dev.spira-la.com

# ─── Cloudflare Cache (optional — cache purge disabled if not set) ───
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
SITE_URL=https://dev.spira-la.com
