# =====================================================================
# Spirala — Root Environment Variables Example
# Copy to .env and fill in the values.
# NEVER commit .env to version control.
# =====================================================================

# ------------------------------------------------------------------
# Cloudflare Tunnel tokens (manual — not used by CI/CD pipeline)
# Obtain from: Cloudflare Zero Trust → Access → Tunnels
# ------------------------------------------------------------------
TUNNEL_TOKEN_PROD=
TUNNEL_TOKEN_DEV=

# ------------------------------------------------------------------
# Supabase (passed as Docker build args for the frontend)
# ------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public API base URL (e.g. https://api.spira-la.com)
VITE_API_URL=

# ------------------------------------------------------------------
# Backend environment variables
# See backend/.env.example for the full list of backend variables.
# ------------------------------------------------------------------
